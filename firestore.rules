rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isGroupMember(groupId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /mocks/{mockId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid ||
        (
          resource.data.groupIds is list &&
          resource.data.groupIds.size() > 0 &&
          isGroupMember(resource.data.groupIds[0])
        )
      );

      allow update, delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /groups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read: if signedIn();

      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid;

      allow delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /draftClasses/{year}/players/{playerId} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}