rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function draftOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function creatingOwnDraft() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function groupOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function groupMember() {
      return signedIn() &&
        resource.data.memberUids is list &&
        request.auth.uid in resource.data.memberUids;
    }

    function creatingOwnGroup() {
      return signedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.resource.data.memberUids is list &&
        request.auth.uid in request.resource.data.memberUids;
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /drafts/{draftId} {
      allow create: if creatingOwnDraft();

      allow read: if draftOwner();

      allow update, delete: if draftOwner();
    }

    match /groups/{groupId} {
      allow create: if creatingOwnGroup();

      allow read: if groupOwner() || groupMember();

      allow update: if groupOwner() || groupMember();

      allow delete: if groupOwner();
    }
  }
}