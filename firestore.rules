rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isDraftOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isCreatingOwnDraft() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    function isGroupOwner() {
      return signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function isGroupMember() {
      return signedIn() && request.auth.uid in resource.data.memberUids;
    }

    function isCreatingOwnGroup() {
      return signedIn() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /drafts/{draftId} {
      allow create: if isCreatingOwnDraft();

      allow read: if isDraftOwner() || (
        signedIn() &&
        resource.data.isPublic == true
      ) || (
        signedIn() &&
        resource.data.groupIds is list &&
        resource.data.groupIds.size() > 0
      );

      allow update, delete: if isDraftOwner();
    }

    match /groups/{groupId} {
      allow create: if isCreatingOwnGroup()
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids;

      allow read: if isGroupOwner() || isGroupMember();

      allow update: if isGroupOwner() || isGroupMember();

      allow delete: if isGroupOwner();
    }
  }
}